# ── API Gateway ─────────────────────────────────────────────────
OBSTACLE_URL=http://obstacle-service:8001
OCR_URL=http://ocr-service:8002
MONEY_URL=http://money-service:8003

# ── Models ──────────────────────────────────────────────────────
OBSTACLE_MODEL_PATH=/app/models/yolo_trained.pt
MONEY_MODEL_PATH=/app/models/money_model.pt
